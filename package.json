{
  "name": "model-preview-service",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"vite build --watch\" \"tsx watch src/server/index.ts\"",
    "build": "vite build",
    "start": "tsx src/server/index.ts",
    "test": "vitest run",
    "e2e": "playwright test",
    "smoke": "npm run build && node scripts/smoke-render.mjs",
    "fixtures": "node scripts/make-fixtures.mjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fastify/multipart": "^10.1.0",
    "@fastify/static": "^10.1.0",
    "extract-zip": "^2.0.1",
    "fastify": "^5.10.0",
    "jszip": "^3.10.1",
    "puppeteer": "^25.3.0",
    "three": "^0.185.1"
  },
  "devDependencies": {
    "@fontsource-variable/manrope": "^5.2.8",
    "@fontsource-variable/plus-jakarta-sans": "^5.2.8",
    "@gltf-transform/core": "^4.4.1",
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.1.1",
    "@types/pngjs": "^6.0.5",
    "@types/three": "^0.185.1",
    "concurrently": "^10.0.3",
    "pngjs": "^7.0.0",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  }
}
